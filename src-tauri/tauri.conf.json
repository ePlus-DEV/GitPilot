{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPilot",
  "version": "0.1.0",
  "identifier": "dev.gitpilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitPilot",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBOUNCMDg4QzJFMkQ2MDYKUldRRzF1TENpTENjeXB5WGtQSHZRc3ViU0RlQVZ5RzcxZHlPM1YwSWd4QzI1Rmk5eVptdWFIU1cK",
      "endpoints": [
        "https://github.com/ePlus-DEV/GitPilot/releases/latest/download/latest.json"
      ]
    }
  }
}
